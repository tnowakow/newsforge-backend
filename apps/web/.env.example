# Frontend API origin. In dev, leave EMPTY so all fetches go through Vite's
# proxy at /api, /uploads, /pdfs, /render (configured in vite.config.ts). In
# Railway prod the API is served from the same origin, so leaving this empty
# also works.
VITE_API_URL=

# Where the Vite dev proxy forwards /api, /uploads, /pdfs, /render. Defaults
# to http://localhost:3001 to match the spec. If your API listens on 3000
# (the backend default), set this to http://localhost:3000.
VITE_DEV_PROXY_TARGET=http://localhost:3001

# Shared with the API's INTERNAL_RENDER_SECRET. The dev proxy injects this on
# every /render/* request so the iframe preview works in dev.
VITE_DEV_RENDER_SECRET=change-me-in-prod
