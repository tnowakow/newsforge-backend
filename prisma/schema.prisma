// NewsForge Prisma schema — locked by Vitaly §2.
// JSON columns are typed at the boundary by Zod schemas in @newsforge/shared.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Richness {
  SIMPLE
  MODERATE
  RICH
  EXTRA_RICH
}

enum CareLevel {
  INDEPENDENT_LIVING
  ASSISTED_LIVING
  MEMORY_CARE
  MIXED
}

enum FillerMode {
  GENERATE
  PLACEHOLDER
}

enum RunStatus {
  DRAFT
  ASSEMBLING
  READY
  ERROR
}

enum AssetType {
  IMAGE
  ARTICLE
}

enum AssetSource {
  MOCK
  UPLOAD
  GENERATED
}

model Client {
  id                String   @id @default(cuid())
  name              String
  tagline           String
  city              String
  careLevel         CareLevel
  richnessLevel     Richness
  logoUrl           String
  primaryColor      String
  secondaryColor    String
  accentColor       String
  headingFont       String
  bodyFont          String
  defaultTemplateId String
  pageCount         Int
  recurringSections Json
  brandVoice        String
  createdAt         DateTime @default(now())

  defaultTemplate Template        @relation("ClientDefaultTemplate", fields: [defaultTemplateId], references: [id])
  runs            NewsletterRun[]
  assets          AssetLibrary[]

  @@index([richnessLevel])
}

model Template {
  id                 String  @id @default(cuid())
  name               String
  pageCount          Int
  gridSpec           Json
  slotTypes          Json
  compatibilityHints Json
  previewImageUrl    String?

  defaultForClients Client[]        @relation("ClientDefaultTemplate")
  runs              NewsletterRun[]
}

model NewsletterRun {
  id              String     @id @default(cuid())
  clientId        String
  templateId      String
  monthLabel      String
  fillerMode      FillerMode
  articles        Json
  images          Json
  assembledLayout Json
  status          RunStatus  @default(DRAFT)
  errorMessage    String?
  pdfPath         String?
  pdfGeneratedAt  DateTime?
  layoutVersion   Int        @default(1)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  client   Client   @relation(fields: [clientId], references: [id])
  template Template @relation(fields: [templateId], references: [id])
  aiEdits  AiEdit[]

  @@index([clientId, createdAt])
}

model AssetLibrary {
  id           String      @id @default(cuid())
  clientId     String?
  type         AssetType
  contentOrUrl String
  source       AssetSource
  meta         Json
  createdAt    DateTime    @default(now())

  client Client? @relation(fields: [clientId], references: [id])

  @@index([clientId, type])
  @@index([type, source])
}

model AiEdit {
  id            String   @id @default(cuid())
  runId         String
  prompt        String
  resultStatus  String
  diffSummary   Json?
  layoutBefore  Json
  layoutAfter   Json?
  geminiLatency Int?
  createdAt     DateTime @default(now())

  run NewsletterRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}
