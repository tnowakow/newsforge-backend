{
  "name": "newsforge-backend",
  "version": "0.1.0",
  "private": true,
  "description": "NewsForge backend — AI newsletter layout engine for senior living. Express + Prisma + Puppeteer + Gemini.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm -w @newsforge/shared run build",
    "build:api": "npm -w @newsforge/api run build",
    "dev": "npm -w @newsforge/api run dev",
    "start": "node apps/api/dist/index.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "release": "prisma migrate deploy --schema prisma/schema.prisma && tsx prisma/seed.ts",
    "typecheck": "tsc -p apps/api/tsconfig.json --noEmit && tsc -p packages/shared/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
