# Database (Railway auto-injects DATABASE_URL on the PG plugin)
DATABASE_URL="postgresql://user:pass@localhost:5432/newsforge"

# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Gemini (Railway env var; NEVER ship to browser)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# AI unlock password (Sofia Screen 6 demo gate)
AI_UNLOCK_PASSWORD="65386538"

# Internal render route guard (paired with 127.0.0.1 check)
INTERNAL_RENDER_SECRET="change-me-in-prod"

# Cookie signing for aiUnlocked cookie
COOKIE_SECRET="change-me-in-prod"

# Puppeteer / Chromium — leave empty to use @sparticuz/chromium bundled binary
PUPPETEER_EXECUTABLE_PATH=""
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Volume paths (Railway mounts at /data; local dev defaults below)
DATA_DIR="./data"
